# Entry point
banner
run_recon_for_domain() {
    domain="$1"
    echo "Running recon for: $domain"
    output_dir="recon/$domain"
    mkdir -p "$output_dir"
    log_file="$output_dir/recon.log"

    log() {
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$log_file"
    }

    # Passive Subdomain Enumeration
    run_passive_recon() {
        log "Running Passive Recon..."
        
        # Resume support
        progress_file="$output_dir/.progress"
        if grep -q "passive_recon:done" "$progress_file" 2>/dev/null && [[ -s "$output_dir/passive_subdomains.txt" ]]; then
            local count=$(wc -l < "$output_dir/passive_subdomains.txt" 2>/dev/null || echo 0)
            log "Passive recon already completed ($count subdomains). Skipping."
            return
        fi

        # Export Chaos API Key
        export CHAOS_KEY=""
        export GITHUB_TOKEN=""
        export SECURITYTRAILS_KEY=""
        export NETLAS_API_KEY=""      
        export ZOOMEYE_API_KEY="" 
        export SHODAN_API_KEY=""                   # Set via env

        # Make sure output dir exists
        mkdir -p "$output_dir"

        # Subfinder
        log "Using Subfinder..."
        subfinder -d "$domain" -o "$output_dir/subfinder.txt" || true

        # Assetfinder
        log "Using Assetfinder..."
        assetfinder --subs-only "$domain" >"$output_dir/assetfinder.txt" || true

        # Sublist3r
        log "Using Sublist3r..."
        sublist3r -d "$domain" -o "$output_dir/sublist3r.txt" || true

        # crt.sh via curl
        log "Using crt.sh..."
        curl -s "https://crt.sh/?q=%25.$domain&output=json" 2>/dev/null |
            jq -r '.[].name_value' 2>/dev/null |
            sed 's/\*\.//g' |
            grep -iE "([a-z0-9_\-]+\.)+$domain$" |
            sort -u >"$output_dir/crtsh.txt" || true

        # ShrewdEye scraping (static HTML parsing)  -->new
        log "Using ShrewdEye..."
        curl -s "https://shrewdeye.app/?q=$domain" 2>/dev/null |
            grep -oP '([a-zA-Z0-9_-]+\.)+'"$domain" |
            sort -u >"$output_dir/shrewdeye.txt" || true

        # SecurityTrails API (requires SECURITYTRAILS_KEY)  -->new
        if [[ -z "${SECURITYTRAILS_KEY:-}" ]]; then
            log "Skipping SecurityTrails: SECURITYTRAILS_KEY not set."
        else
            log "Using SecurityTrails API..."
            curl -s -H "APIKEY: $SECURITYTRAILS_KEY" \
                "https://api.securitytrails.com/v1/domain/$domain/subdomains" 2>/dev/null |
                jq -r '.subdomains[]' 2>/dev/null |
                sed "s|$|.$domain|" |
                sort -u >"$output_dir/securitytrails.txt" || true
        fi

        # Findomain
        log "Using Findomain..."
        findomain --target "$domain" --quiet --output || true
        [[ -f "$domain.txt" ]] && mv "$domain.txt" "$output_dir/findomain.txt" || touch "$output_dir/findomain.txt"

        # Chaos
        log "Using Chaos dataset..."
        chaos -d "$domain" -o "$output_dir/chaos.txt" || true

        # GitHub Subdomains (requires GitHub token set in env var)
        if [[ -n "${GITHUB_TOKEN:-}" ]]; then
            log "Using GitHub-subdomains..."
            github-subdomains -d "$domain" -t "$GITHUB_TOKEN" -o "$output_dir/github.txt" || true
        else
            log "Skipping GitHub-subdomains: GITHUB_TOKEN not set."
        fi

        # Netlas.io (requires API key) #-->new
        if [[ -n "${NETLAS_API_KEY:-}" ]]; then
            log "Using Netlas.io..."
            curl -s "https://app.netlas.io/api/domains?q=domain:$domain" \
                -H "X-API-Key: $NETLAS_API_KEY" 2>/dev/null |
                jq -r '.items[].name' 2>/dev/null |
                grep "$domain" |
                sort -u >"$output_dir/netlas.txt" || true
        else
            log "Skipping Netlas.io: API key not set."
        fi

        # Bufferover.run #-->new
        log "Using Bufferover..."
        curl -s "https://dns.bufferover.run/dns?q=.$domain" 2>/dev/null |
            jq -r '.FDNS_A[]?' 2>/dev/null |
            cut -d',' -f2 |
            grep "$domain" |
            sort -u >"$output_dir/bufferover.txt" || true

        # Zoomeye (requires API key) #-->new
        if [[ -n "${ZOOMEYE_API_KEY:-}" ]]; then
            log "Using Zoomeye..."
            curl -s -H "API-KEY: $ZOOMEYE_API_KEY" \
                "https://api.zoomeye.org/domain/search?q=$domain" 2>/dev/null |
                jq -r '.matches[].name' 2>/dev/null |
                grep "$domain" |
                sort -u >"$output_dir/zoomeye.txt" || true
        else
            log "Skipping Zoomeye: API key not set."
        fi

        # LeakIX #-->new
        log "Using LeakIX..."
        curl -s "https://leakix.net/domain/$domain" 2>/dev/null |
            grep -oP '([a-zA-Z0-9_-]+\.)+'"$domain" |
            sort -u >"$output_dir/leakix.txt" || true

        # Combine & deduplicate all results into passive_subdomains.txt
        log "Combining and sorting results..."
        tmp_combined="$output_dir/tmp_combined_passive.txt"
        cat "$output_dir"/*.txt 2>/dev/null | sort -u >"$tmp_combined" || true
        mv "$tmp_combined" "$output_dir/passive_subdomains.txt" || true

        # Clean up all temp files except passive_subdomains.txt
        log "Cleaning up temporary files..."
        find "$output_dir" -type f -name '*.txt' ! -name 'passive_subdomains.txt' -delete || true

        # Wildcard detection
        log "Checking for wildcard DNS..."
        wildcard_ip=$(dig +short "randomnonexistent$(date +%s).$domain" 2>/dev/null | head -1 || true)
        if [[ -n "$wildcard_ip" ]]; then
            log "WARNING: Wildcard DNS detected ($wildcard_ip) - filtering results..."
            grep -v "$wildcard_ip" "$output_dir/passive_subdomains.txt" > "$output_dir/passive_filtered.txt" || true
            mv "$output_dir/passive_filtered.txt" "$output_dir/passive_subdomains.txt"
        fi

        # DNS Resolution Validation
        log "Validating subdomains via DNS resolution..."
        cat "$output_dir/passive_subdomains.txt" | dnsx -silent -o "$output_dir/resolved_subdomains.txt" || true
        if [[ -s "$output_dir/resolved_subdomains.txt" ]]; then
            mv "$output_dir/resolved_subdomains.txt" "$output_dir/passive_subdomains.txt"
        fi
        
        echo "passive_recon:done" >> "$progress_file"
        log "Passive recon completed. Results saved to $output_dir/passive_subdomains.txt"
    }

    # Check if subdomain resolves (DNS pre-check for FFUF optimization)
    dns_resolves() {
        local host="$1"
        dig +short "$host" 2>/dev/null | grep -qE '^[0-9]+\.' && return 0
        host "$host" 2>/dev/null | grep -q "has address" && return 0
        return 1
    }

    # Active Subdomain Enumeration via FFUF Subdomain Fuzzing (OPTIMIZED)
    run_active_recon() {
        log "Running FFUF Subdomain Fuzzing (Optimized)..."
        wordlist="/usr/share/dirb/wordlists/common.txt"
        
        # Resume support - check if already completed
        progress_file="$output_dir/.progress"
        if grep -q "active_recon:done" "$progress_file" 2>/dev/null && [[ -s "$output_dir/active_subdomains.txt" ]]; then
            log "Active recon already completed. Skipping. (Delete $progress_file to force re-run)"
            return
        fi

        mkdir -p "$output_dir"
        
        # Resume support - load previous results
        tmp_file="$output_dir/tmp_active_subdomains.txt"
        processed_file="$output_dir/.ffuf_processed.txt"
        
        if [[ -f "$tmp_file" ]]; then
            log "Resuming from previous run..."
        else
            >"$tmp_file"
        fi
        touch "$processed_file"

        # DNS pre-check: only fuzz if base domain resolves
        if ! dns_resolves "$domain"; then
            log "WARNING: Base domain $domain does not resolve. Skipping FFUF."
            touch "$output_dir/active_subdomains.txt"
            echo "active_recon:done" >> "$progress_file"
            return
        fi

        # Level 1 - with optimized filters
        log "[Level 1] Fuzzing FUZZ.$domain"
        # Filter: -fc 404 (not found), -fs 0 (empty response), -mc matches success codes
        ffuf -w "$wordlist" -u "https://FUZZ.$domain" -H "Host: FUZZ.$domain" \
            -mc 200,201,204,301,302,307,308,401,403,405,500 \
            -fc 404 -fs 0 \
            -rate 150 -timeout 5 -t 50 \
            -s -o "$output_dir/ffuf_lvl1.json" -of json 2>/dev/null || true
        
        level1_results=$(jq -r '.results[].input.FUZZ // empty' "$output_dir/ffuf_lvl1.json" 2>/dev/null) || level1_results=""

        if [[ -n "$level1_results" ]]; then
            echo "$level1_results" | sed "s|$|.$domain|" >>"$tmp_file"
            
            # Level 2 - only for resolved subdomains
            for sub1 in $level1_results; do
                full_sub="$sub1.$domain"
                
                # Skip if already processed (resume support)
                if grep -qxF "$full_sub" "$processed_file" 2>/dev/null; then
                    log "[Level 2] Skipping $full_sub (already processed)"
                    continue
                fi
                
                # DNS pre-check - skip if doesn't resolve
                if ! dns_resolves "$full_sub"; then
                    log "[Level 2] Skipping $full_sub (no DNS)"
                    echo "$full_sub" >> "$processed_file"
                    continue
                fi
                
                log "[Level 2] Fuzzing FUZZ.$full_sub"
                ffuf -w "$wordlist" -u "https://FUZZ.$full_sub" -H "Host: FUZZ.$full_sub" \
                    -mc 200,201,204,301,302,307,308,401,403,405,500 \
                    -fc 404 -fs 0 \
                    -rate 150 -timeout 5 -t 50 \
                    -s -o "$output_dir/ffuf_lvl2_${sub1}.json" -of json 2>/dev/null || true
                
                level2_results=$(jq -r '.results[].input.FUZZ // empty' "$output_dir/ffuf_lvl2_${sub1}.json" 2>/dev/null) || level2_results=""
                echo "$full_sub" >> "$processed_file"

                if [[ -n "$level2_results" ]]; then
                    echo "$level2_results" | sed "s|$|.$full_sub|" >>"$tmp_file"
                    # Skip level 3 - too time consuming, diminishing returns
                fi
                rm -f "$output_dir/ffuf_lvl2_${sub1}.json"
            done
        else
            log "No results found at Level 1."
        fi
        rm -f "$output_dir/ffuf_lvl1.json"

        # Deduplicate and save
        sort -u "$tmp_file" >"$output_dir/active_subdomains.txt" 2>/dev/null || true
        rm -f "$tmp_file" "$processed_file"
        
        echo "active_recon:done" >> "$progress_file"
        log "Active recon completed. Results saved to $output_dir/active_subdomains.txt"
    }

    # Fuzzing Passive Subdomains with ffuf (OPTIMIZED)
    run_ffuf_passive() {
        log "Fuzzing passive subdomains with ffuf (Optimized)..."
        wordlist="/usr/share/dirb/wordlists/common.txt"
        passive_file="$output_dir/passive_subdomains.txt"
        
        # Resume support
        progress_file="$output_dir/.progress"
        if grep -q "ffuf_passive:done" "$progress_file" 2>/dev/null && [[ -s "$output_dir/active_passive_subdomains.txt" ]]; then
            log "Passive FFUF already completed. Skipping."
            return
        fi

        mkdir -p "$output_dir"

        tmp_file="$output_dir/tmp_active_passive.txt"
        processed_file="$output_dir/.ffuf_passive_processed.txt"
        
        # Resume support - append to existing results
        if [[ -f "$tmp_file" ]]; then
            log "Resuming passive FFUF from previous run..."
        else
            >"$tmp_file"
        fi
        touch "$processed_file"

        # Limit to first 100 passive subdomains to avoid excessive time
        total_passive=$(wc -l < "$passive_file" 2>/dev/null || echo 0)
        if [[ "$total_passive" -gt 100 ]]; then
            log "WARNING: $total_passive subdomains found. Limiting to first 100."
            head -100 "$passive_file" > "$passive_file.limited"
            passive_file="$passive_file.limited"
        fi

        while read -r base; do
            [[ -z "$base" ]] && continue
            
            # Skip if already processed
            if grep -qxF "$base" "$processed_file" 2>/dev/null; then
                continue
            fi
            
            # DNS pre-check
            if ! dns_resolves "$base"; then
                log "Skipping $base (no DNS resolution)"
                echo "$base" >> "$processed_file"
                continue
            fi

            log "[Level 1] Fuzzing FUZZ.$base"
            ffuf -w "$wordlist" -u "https://FUZZ.$base" -H "Host: FUZZ.$base" \
                -mc 200,201,204,301,302,307,308,401,403,405,500 \
                -fc 404 -fs 0 \
                -rate 150 -timeout 5 -t 50 \
                -s -o "$output_dir/ffuf_passive_${base//[^a-zA-Z0-9]/_}.json" -of json 2>/dev/null || true
            
            fuzz_results=$(jq -r '.results[].input.FUZZ // empty' "$output_dir/ffuf_passive_${base//[^a-zA-Z0-9]/_}.json" 2>/dev/null) || fuzz_results=""
            
            if [[ -n "$fuzz_results" ]]; then
                echo "$fuzz_results" | sed "s|$|.$base|" >>"$tmp_file"
            fi
            
            rm -f "$output_dir/ffuf_passive_${base//[^a-zA-Z0-9]/_}.json"
            echo "$base" >> "$processed_file"
            
        done <"$passive_file"

        # Cleanup limited file
        rm -f "$passive_file.limited"
        
        # Deduplicate and save
        sort -u "$tmp_file" >"$output_dir/active_passive_subdomains.txt" 2>/dev/null || true
        rm -f "$tmp_file" "$processed_file"
        
        echo "ffuf_passive:done" >> "$progress_file"
        log "Passive fuzzing completed. Results saved to $output_dir/active_passive_subdomains.txt"
    }

    # HTTP Probing 1
    run_httpx1() {
        # Resume support
        progress_file="$output_dir/.progress"
        if grep -q "httpx1:done" "$progress_file" 2>/dev/null && [[ -s "$output_dir/final_live_subdomains.txt" ]]; then
            local count=$(wc -l < "$output_dir/final_live_subdomains.txt" 2>/dev/null || echo 0)
            log "HTTP probing already completed ($count live hosts). Skipping."
            return
        fi
        
        log "Probing live subdomains with Httpx..."

        combined_file="$output_dir/combined_subdomains.txt"
        cat "$output_dir/active_subdomains.txt" "$output_dir/passive_subdomains.txt" "$output_dir/active_passive_subdomains.txt" 2>/dev/null | sort -u >"$combined_file"

        cat "$combined_file" | httpx -mc 200,201,301,302,307,308,401,403,405 -fc 404,502,503,504 -timeout 10 -o "$output_dir/final_live_subdomains.txt" || true

        rm -f "$combined_file"
        
        echo "httpx1:done" >> "$progress_file"
        log "Httpx probing completed. Results saved to $output_dir/final_live_subdomains.txt"
    }

    #run_dirsearch_batch
    run_dirsearch_batch() {
        # Resume support
        progress_file="$output_dir/.progress"
        if grep -q "dirsearch:done" "$progress_file" 2>/dev/null && [[ -s "$output_dir/dirsearch_valid_urls.txt" ]]; then
            log "Dirsearch already completed. Skipping."
            return
        fi
        
        log "Running Dirsearch on all live subdomains..."

        input_file="$output_dir/final_live_subdomains.txt"
        output_file="$output_dir/dirsearch_valid_urls.txt"

        if [[ ! -f "$input_file" ]]; then
            echo -e "${RED}Error:${RESET} $input_file not found."
            return
        fi

        dirsearch_exts="conf,config,bak,backup,swp,old,db,sql,asp,aspx,asp~,py,py~,rb,rb~,php,php~,bkp,cache,cgi,csv,html,inc,jar,js,json,jsp,jsp~,lock,log,rar,sql.gz,sql.tar.gz,sql~,swp~,tar,tar.bz2,tar.gz,txt,wadl,zip,xml"

        python3 dirsearch/dirsearch.py \
            -l "$input_file" \
            -e "$dirsearch_exts" \
            --plain-text-report "$output_file" || true
        
        echo "dirsearch:done" >> "$progress_file"
        log "Dirsearch scan completed. Results saved to $output_file"
    }

    # Crawling with Katana
    run_katana() {
        progress_file="$output_dir/.progress"
        if grep -q "katana:done" "$progress_file" 2>/dev/null && [[ -s "$output_dir/katana_urls.txt" ]]; then
            log "Katana crawling already completed. Skipping."
            return
        fi
        log "Running Katana for web crawling..."
        katana -list "$output_dir/final_live_subdomains.txt" -depth 3 -o "$output_dir/katana_urls.txt" || true
        echo "katana:done" >> "$progress_file"
    }

    # Extract URLs from Wayback Machine
    run_waybackurls() {
        progress_file="$output_dir/.progress"
        if grep -q "wayback:done" "$progress_file" 2>/dev/null && [[ -s "$output_dir/wayback_urls.txt" ]]; then
            log "Wayback URLs already fetched. Skipping."
            return
        fi
        log "Extracting URLs from Wayback Machine..."
        cat "$output_dir/final_live_subdomains.txt" | waybackurls >"$output_dir/wayback_urls.txt" || true
        echo "wayback:done" >> "$progress_file"
    }

    # Run GAU to fetch URLs
    run_gau() {
        progress_file="$output_dir/.progress"
        if grep -q "gau:done" "$progress_file" 2>/dev/null && [[ -s "$output_dir/gau_all_urls.txt" ]]; then
            log "GAU already completed. Skipping."
            return
        fi
        log "Running GAU for historical URL fetching..."
        combined_output="$output_dir/gau_all_urls.txt"
        >"$combined_output"

        while read -r subdomain; do
            log "Fetching URLs for $subdomain with GAU..."
            gau "$subdomain" >>"$combined_output" || true
        done <"$output_dir/final_live_subdomains.txt" || true

        sort -u "$combined_output" -o "$combined_output" 2>/dev/null || true
        
        echo "gau:done" >> "$progress_file"
        log "GAU completed. All URLs saved to $combined_output"
    }

    # Combine all URLs into all_urls.txt
    combine_all_urls() {
        progress_file="$output_dir/.progress"
        if grep -q "combine_urls:done" "$progress_file" 2>/dev/null && [[ -s "$output_dir/all_urls.txt" ]]; then
            log "URLs already combined. Skipping."
            return
        fi
        log "Combining Katana, Waybackurls, and GAU outputs..."
        cat "$output_dir/katana_urls.txt" \
            "$output_dir/wayback_urls.txt" \
            "$output_dir/gau_all_urls.txt" 2>/dev/null |
            sort -u >"$output_dir/all_urls.txt" || true
        
        echo "combine_urls:done" >> "$progress_file"
        log "All URLs combined into $output_dir/all_urls.txt"
    }

    # HTTP Probing 2
    run_httpx2() {
        progress_file="$output_dir/.progress"
        if grep -q "httpx2:done" "$progress_file" 2>/dev/null && [[ -s "$output_dir/final_all_urls.txt" ]]; then
            log "URL probing already completed. Skipping."
            return
        fi
        log "Probing all_urls.txt with Httpx..."

        cat "$output_dir/all_urls.txt" | httpx -mc 200,201,301,302,307,308,401,403,405 -fc 404,502,503,504 -timeout 10 -o "$output_dir/final_all_urls.txt" || true
        
        echo "httpx2:done" >> "$progress_file"
        log "Httpx probing completed. Results saved to $output_dir/final_all_urls.txt"
    }

    # Filtering URLs by extensions
    filter_urls() {
        progress_file="$output_dir/.progress"
        if grep -q "filter_urls:done" "$progress_file" 2>/dev/null && [[ -d "$output_dir/urls" ]]; then
            log "URL filtering already completed. Skipping."
            return
        fi
        log "Filtering URLs by file extensions..."

        # Create the directory if it doesn't exist
        mkdir -p "$output_dir/urls"

        grep -iE '\.js([/?].*)?$' "$output_dir/all_urls.txt" >"$output_dir/urls/js_urls.txt" || true
        grep -iE '\.php([/?].*)?$' "$output_dir/all_urls.txt" >"$output_dir/urls/php_urls.txt" || true
        grep -iE '\.aspx([/?].*)?$' "$output_dir/all_urls.txt" >"$output_dir/urls/aspx_urls.txt" || true
        grep -iE '\.jsp([/?].*)?$' "$output_dir/all_urls.txt" >"$output_dir/urls/jsp_urls.txt" || true
        grep -iE '\.json([/?].*)?$' "$output_dir/all_urls.txt" >"$output_dir/urls/json_urls.txt" || true
        grep -iE '\.txt([/?].*)?$' "$output_dir/all_urls.txt" >"$output_dir/urls/txt_urls.txt" || true
        grep -iE '\.html([/?].*)?$' "$output_dir/all_urls.txt" >"$output_dir/urls/html_urls.txt" || true
        grep -iE '\.css([/?].*)?$' "$output_dir/all_urls.txt" >"$output_dir/urls/css_urls.txt" || true
        # Keyword filters (auth-related endpoints)
        grep -iE 'login|signin|signup|auth|register|logout|password|reset' "$output_dir/all_urls.txt" >"$output_dir/urls/auth_urls.txt" || true
        
        echo "filter_urls:done" >> "$progress_file"
        log "Filtering URLs by file extensions completed. Results saved in $output_dir."
    }

    # JavaScript Analysis Module
    run_js_analysis() {
        progress_file="$output_dir/.progress"
        if grep -q "js_analysis:done" "$progress_file" 2>/dev/null && [[ -f "$output_dir/js_analysis/SUMMARY.txt" ]]; then
            log "JS analysis already completed. Skipping."
            return
        fi
        log "Running JavaScript Analysis..."
        
        js_input="$output_dir/urls/js_urls.txt"
        js_dir="$output_dir/js_analysis"
        mkdir -p "$js_dir"
        
        if [[ ! -f "$js_input" || ! -s "$js_input" ]]; then
            log "No JS files found. Skipping JS analysis."
            return
        fi
        
        js_count=$(wc -l < "$js_input")
        log "Analyzing $js_count JavaScript files..."
        
        # 1. Download JS files for local analysis
        log "Downloading JS files..."
        mkdir -p "$js_dir/files"
        > "$js_dir/downloaded.txt"
        
        while read -r js_url; do
            [[ -z "$js_url" ]] && continue
            filename=$(echo "$js_url" | md5sum | cut -d' ' -f1).js
            curl -s -L --max-time 10 "$js_url" -o "$js_dir/files/$filename" 2>/dev/null && \
                echo "$js_url|$filename" >> "$js_dir/downloaded.txt" || true
        done < "$js_input"
        
        downloaded_count=$(find "$js_dir/files" -name "*.js" -size +0 | wc -l)
        log "Downloaded $downloaded_count JS files."
        
        # 2. Extract URLs/Endpoints with jsluice
        log "Extracting endpoints with jsluice..."
        > "$js_dir/endpoints_raw.txt"
        
        for jsfile in "$js_dir/files"/*.js; do
            [[ -f "$jsfile" ]] || continue
            jsluice urls < "$jsfile" 2>/dev/null >> "$js_dir/endpoints_raw.txt" || true
        done
        
        # Parse jsluice JSON output and extract URLs
        jq -r '.url // empty' "$js_dir/endpoints_raw.txt" 2>/dev/null | sort -u > "$js_dir/endpoints.txt" || true
        
        # 3. Extract secrets with jsluice
        log "Extracting secrets with jsluice..."
        > "$js_dir/secrets_raw.txt"
        
        for jsfile in "$js_dir/files"/*.js; do
            [[ -f "$jsfile" ]] || continue
            jsluice secrets < "$jsfile" 2>/dev/null >> "$js_dir/secrets_raw.txt" || true
        done
        
        # Parse secrets output
        jq -r 'select(.kind and .data) | "\(.kind): \(.data)"' "$js_dir/secrets_raw.txt" 2>/dev/null | \
            sort -u > "$js_dir/secrets.txt" || true
        
        # 4. Regex-based secret extraction (backup/additional patterns)
        log "Running regex-based secret extraction..."
        > "$js_dir/secrets_regex.txt"
        
        # AWS Keys
        grep -rhoP 'AKIA[0-9A-Z]{16}' "$js_dir/files/" 2>/dev/null | sort -u | \
            sed 's/^/AWS_ACCESS_KEY: /' >> "$js_dir/secrets_regex.txt" || true
        
        # AWS Secret Keys
        grep -rhoP '(?<=AWS_SECRET_ACCESS_KEY["\x27=: ]{1,5})[A-Za-z0-9/+=]{40}' "$js_dir/files/" 2>/dev/null | sort -u | \
            sed 's/^/AWS_SECRET: /' >> "$js_dir/secrets_regex.txt" || true
        
        # Google API Keys
        grep -rhoP 'AIza[0-9A-Za-z_-]{35}' "$js_dir/files/" 2>/dev/null | sort -u | \
            sed 's/^/GOOGLE_API: /' >> "$js_dir/secrets_regex.txt" || true
        
        # GitHub Tokens
        grep -rhoP '(ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9_]{36,}' "$js_dir/files/" 2>/dev/null | sort -u | \
            sed 's/^/GITHUB_TOKEN: /' >> "$js_dir/secrets_regex.txt" || true
        
        # JWT Tokens
        grep -rhoP 'eyJ[A-Za-z0-9_-]*\.eyJ[A-Za-z0-9_-]*\.[A-Za-z0-9_-]*' "$js_dir/files/" 2>/dev/null | sort -u | \
            sed 's/^/JWT: /' >> "$js_dir/secrets_regex.txt" || true
        
        # Private Keys
        grep -rhoP '\-\-\-\-\-BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY\-\-\-\-\-' "$js_dir/files/" 2>/dev/null | sort -u | \
            sed 's/^/PRIVATE_KEY_HEADER: /' >> "$js_dir/secrets_regex.txt" || true
        
        # Slack Tokens
        grep -rhoP 'xox[baprs]-[0-9]{10,13}-[0-9]{10,13}[a-zA-Z0-9-]*' "$js_dir/files/" 2>/dev/null | sort -u | \
            sed 's/^/SLACK_TOKEN: /' >> "$js_dir/secrets_regex.txt" || true
        
        # Stripe Keys
        grep -rhoP 'sk_live_[0-9a-zA-Z]{24,}' "$js_dir/files/" 2>/dev/null | sort -u | \
            sed 's/^/STRIPE_SECRET: /' >> "$js_dir/secrets_regex.txt" || true
        grep -rhoP 'pk_live_[0-9a-zA-Z]{24,}' "$js_dir/files/" 2>/dev/null | sort -u | \
            sed 's/^/STRIPE_PUBLISHABLE: /' >> "$js_dir/secrets_regex.txt" || true
        
        # Firebase
        grep -rhoP '[a-z0-9-]+\.firebaseio\.com' "$js_dir/files/" 2>/dev/null | sort -u | \
            sed 's/^/FIREBASE_URL: /' >> "$js_dir/secrets_regex.txt" || true
        
        # Generic API keys (potential false positives)
        grep -rhoP '(?i)(api[_-]?key|apikey|api[_-]?secret)["\x27=: ]{1,5}[A-Za-z0-9_-]{16,}' "$js_dir/files/" 2>/dev/null | sort -u | \
            sed 's/^/GENERIC_API: /' >> "$js_dir/secrets_regex.txt" || true
        
        # Authorization headers
        grep -rhoP '(?i)(authorization|bearer|token)["\x27=: ]{1,5}[A-Za-z0-9_-]{20,}' "$js_dir/files/" 2>/dev/null | sort -u | \
            sed 's/^/AUTH_HEADER: /' >> "$js_dir/secrets_regex.txt" || true
        
        # 5. Extract API endpoints and paths
        log "Extracting API paths..."
        > "$js_dir/api_paths.txt"
        
        # Common API patterns
        grep -rhoP '["'"'"'](/api/[^"'"'"'\s<>]+)["'"'"']' "$js_dir/files/" 2>/dev/null | \
            tr -d "\"'" | sort -u >> "$js_dir/api_paths.txt" || true
        
        grep -rhoP '["'"'"'](/v[0-9]+/[^"'"'"'\s<>]+)["'"'"']' "$js_dir/files/" 2>/dev/null | \
            tr -d "\"'" | sort -u >> "$js_dir/api_paths.txt" || true
        
        grep -rhoP '["'"'"'](/graphql[^"'"'"'\s<>]*)["'"'"']' "$js_dir/files/" 2>/dev/null | \
            tr -d "\"'" | sort -u >> "$js_dir/api_paths.txt" || true
        
        # Extract full URLs from JS
        grep -rhoP 'https?://[^"'"'"'\s<>()]+' "$js_dir/files/" 2>/dev/null | \
            sort -u > "$js_dir/extracted_urls.txt" || true
        
        # 6. Extract domains/subdomains
        log "Extracting domains from JS..."
        grep -rhoP '(?:https?://)?([a-zA-Z0-9][-a-zA-Z0-9]*\.)+[a-zA-Z]{2,}' "$js_dir/files/" 2>/dev/null | \
            sed 's|https\?://||g' | sort -u > "$js_dir/domains.txt" || true
        
        # Filter to in-scope domains only
        grep -i "$domain" "$js_dir/domains.txt" > "$js_dir/inscope_domains.txt" 2>/dev/null || true
        
        # 7. Extract potential sensitive paths
        log "Extracting sensitive paths..."
        grep -rhoP '["'"'"']([^"'"'"']*(?:admin|config|backup|database|debug|test|dev|staging|internal|private|secret|upload|download|export|import|dump)[^"'"'"']*)["'"'"']' "$js_dir/files/" 2>/dev/null | \
            tr -d "\"'" | sort -u > "$js_dir/sensitive_paths.txt" || true
        
        # 8. Combine all secrets
        log "Combining all findings..."
        cat "$js_dir/secrets.txt" "$js_dir/secrets_regex.txt" 2>/dev/null | \
            sort -u > "$js_dir/all_secrets.txt" || true
        
        # 9. Build full URLs from paths + live hosts
        log "Building full URLs for testing..."
        > "$js_dir/testable_urls.txt"
        
        if [[ -f "$output_dir/final_live_subdomains.txt" ]]; then
            while read -r base_url; do
                [[ -z "$base_url" ]] && continue
                # Strip trailing slash
                base_url="${base_url%/}"
                
                while read -r path; do
                    [[ -z "$path" ]] && continue
                    # Ensure path starts with /
                    [[ "$path" != /* ]] && path="/$path"
                    echo "${base_url}${path}" >> "$js_dir/testable_urls.txt"
                done < "$js_dir/api_paths.txt"
            done < <(head -20 "$output_dir/final_live_subdomains.txt")  # Limit to first 20 hosts
        fi
        
        sort -u "$js_dir/testable_urls.txt" -o "$js_dir/testable_urls.txt"
        
        # 10. Probe extracted URLs
        log "Probing extracted endpoints..."
        cat "$js_dir/testable_urls.txt" "$js_dir/extracted_urls.txt" 2>/dev/null | sort -u | \
            httpx -silent -mc 200,201,204,301,302,307,401,403,405 -timeout 5 \
            -o "$js_dir/live_endpoints.txt" 2>/dev/null || true
        
        # 11. Create summary
        endpoints_found=$(wc -l < "$js_dir/endpoints.txt" 2>/dev/null || echo 0)
        secrets_found=$(wc -l < "$js_dir/all_secrets.txt" 2>/dev/null || echo 0)
        api_paths_found=$(wc -l < "$js_dir/api_paths.txt" 2>/dev/null || echo 0)
        live_endpoints=$(wc -l < "$js_dir/live_endpoints.txt" 2>/dev/null || echo 0)
        inscope_domains=$(wc -l < "$js_dir/inscope_domains.txt" 2>/dev/null || echo 0)
        
        cat > "$js_dir/SUMMARY.txt" << EOF
═══════════════════════════════════════════════════════════
  JAVASCRIPT ANALYSIS SUMMARY - $domain
═══════════════════════════════════════════════════════════

JS Files Analyzed:    $downloaded_count
Secrets Found:        $secrets_found
API Paths Found:      $api_paths_found
Live Endpoints:       $live_endpoints
In-scope Domains:     $inscope_domains

FILES:
  - all_secrets.txt       → Leaked credentials/keys
  - api_paths.txt         → API endpoints discovered
  - live_endpoints.txt    → Verified live endpoints
  - sensitive_paths.txt   → Admin/config/backup paths
  - inscope_domains.txt   → Discovered subdomains
  - testable_urls.txt     → Full URLs for nuclei

NEXT STEPS:
  1. Review secrets: cat $js_dir/all_secrets.txt
  2. Test endpoints: nuclei -l $js_dir/live_endpoints.txt -t exposures/
  3. Fuzz API paths: ffuf -w $js_dir/api_paths.txt -u https://target/FUZZ

═══════════════════════════════════════════════════════════
EOF
        
        cat "$js_dir/SUMMARY.txt" | tee -a "$log_file"
        
        # 12. Add to nuclei targets
        if [[ -f "$js_dir/live_endpoints.txt" && -s "$js_dir/live_endpoints.txt" ]]; then
            cat "$js_dir/live_endpoints.txt" >> "$output_dir/nuclei/all_targets.txt" 2>/dev/null || true
            sort -u "$output_dir/nuclei/all_targets.txt" -o "$output_dir/nuclei/all_targets.txt" 2>/dev/null || true
        fi
        
        echo "js_analysis:done" >> "$progress_file"
        log "JavaScript analysis completed. Results in $js_dir/"
    }

    # Shodan Hunting Module
    run_shodan_recon() {
        progress_file="$output_dir/.progress"
        if grep -q "shodan_recon:done" "$progress_file" 2>/dev/null && [[ -d "$output_dir/shodan" ]]; then
            log "Shodan recon already completed. Skipping."
            return
        fi
        log "Running Shodan Recon..."
        
        # API Key check
        if [[ -z "${SHODAN_API_KEY:-}" ]]; then
            log "Skipping Shodan: SHODAN_API_KEY not set."
            return
        fi
        
        mkdir -p "$output_dir/shodan"
        
        # 1. Domain search - find subdomains via Shodan DNS
        log "Searching Shodan for domain subdomains..."
        curl -s "https://api.shodan.io/dns/domain/$domain?key=$SHODAN_API_KEY" | \
            jq -r '.subdomains[]?' 2>/dev/null | sed "s|$|.$domain|" > "$output_dir/shodan/subdomains.txt" || true
        
        # 2. Get IPs for all discovered subdomains
        log "Resolving IPs for Shodan host lookup..."
        cat "$output_dir/passive_subdomains.txt" "$output_dir/shodan/subdomains.txt" 2>/dev/null | \
            sort -u | dnsx -silent -a -resp-only 2>/dev/null | \
            sort -u > "$output_dir/shodan/target_ips.txt" || true
        
        # 3. Query each IP for detailed host info (with rate limiting)
        log "Querying Shodan for host details..."
        > "$output_dir/shodan/host_details.jsonl"
        while read -r ip; do
            [[ -z "$ip" ]] && continue
            curl -s "https://api.shodan.io/shodan/host/$ip?key=$SHODAN_API_KEY" >> "$output_dir/shodan/host_details.jsonl"
            echo "" >> "$output_dir/shodan/host_details.jsonl"
            sleep 1  # Rate limiting to avoid API blocks
        done < "$output_dir/shodan/target_ips.txt"
        
        # 4. Extract open ports
        log "Extracting open ports..."
        jq -r 'select(.ip_str and .ports) | .ip_str as $ip | .ports[] | "\($ip):\(.)"' \
            "$output_dir/shodan/host_details.jsonl" 2>/dev/null | \
            sort -u > "$output_dir/shodan/open_ports.txt" || true
        
        # 5. Extract services/banners
        log "Extracting services and banners..."
        jq -r 'select(.data) | .data[] | "\(.ip_str):\(.port) | \(.transport // "tcp") | \(.product // "unknown") \(.version // "") | \(.info // "")"' \
            "$output_dir/shodan/host_details.jsonl" 2>/dev/null | \
            sort -u > "$output_dir/shodan/services.txt" || true
        
        # 6. Extract CVEs/Vulnerabilities
        log "Extracting vulnerabilities..."
        jq -r 'select(.vulns) | .ip_str as $ip | .vulns | keys[] | "\($ip),\(.)"' \
            "$output_dir/shodan/host_details.jsonl" 2>/dev/null | \
            sort -u > "$output_dir/shodan/cves.txt" || true
        
        # 7. Extract SSL certificate CNs (potential new subdomains)
        log "Extracting SSL certificate data..."
        jq -r '.data[]? | select(.ssl) | .ssl.cert.subject.CN? // empty' \
            "$output_dir/shodan/host_details.jsonl" 2>/dev/null | \
            grep -v null | grep "$domain" | sort -u > "$output_dir/shodan/ssl_cns.txt" || true
        
        # 8. Extract hostnames from Shodan data
        jq -r '.hostnames[]?' "$output_dir/shodan/host_details.jsonl" 2>/dev/null | \
            grep "$domain" | sort -u > "$output_dir/shodan/hostnames.txt" || true
        
        echo "shodan_recon:done" >> "$progress_file"
        log "Shodan recon completed. Results in $output_dir/shodan/"
    }

    # Shodan Dork Hunting
    run_shodan_dorks() {
        progress_file="$output_dir/.progress"
        if grep -q "shodan_dorks:done" "$progress_file" 2>/dev/null && [[ -f "$output_dir/shodan/dork_ips.txt" ]]; then
            log "Shodan dorks already completed. Skipping."
            return
        fi
        log "Running Shodan dork searches..."
        
        if [[ -z "${SHODAN_API_KEY:-}" ]]; then
            log "Skipping Shodan dorks: SHODAN_API_KEY not set."
            return
        fi
        
        mkdir -p "$output_dir/shodan"
        
        # Define dorks
        dorks=(
            "ssl:$domain"
            "hostname:$domain"
            "http.title:$domain"
            "ssl.cert.subject.cn:$domain"
            "ssl.cert.issuer.cn:$domain"
        )
        
        > "$output_dir/shodan/dork_results.jsonl"
        
        for dork in "${dorks[@]}"; do
            log "Searching: $dork"
            encoded=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$dork'))")
            curl -s "https://api.shodan.io/shodan/host/search?key=$SHODAN_API_KEY&query=$encoded" >> "$output_dir/shodan/dork_results.jsonl"
            echo "" >> "$output_dir/shodan/dork_results.jsonl"
            sleep 1
        done
        
        # Extract unique IPs from dork results
        jq -r '.matches[]?.ip_str?' "$output_dir/shodan/dork_results.jsonl" 2>/dev/null | \
            sort -u > "$output_dir/shodan/dork_ips.txt" || true
        
        # Extract ports from dork results
        jq -r '.matches[]? | "\(.ip_str):\(.port)"' "$output_dir/shodan/dork_results.jsonl" 2>/dev/null | \
            sort -u >> "$output_dir/shodan/open_ports.txt" || true
        
        sort -u "$output_dir/shodan/open_ports.txt" -o "$output_dir/shodan/open_ports.txt"
        
        echo "shodan_dorks:done" >> "$progress_file"
        log "Shodan dork hunting completed."
    }

    # Generate Nuclei-Ready Targets
    prepare_nuclei_targets() {
        progress_file="$output_dir/.progress"
        if grep -q "nuclei_targets:done" "$progress_file" 2>/dev/null && [[ -f "$output_dir/nuclei/run_nuclei.sh" ]]; then
            log "Nuclei targets already prepared. Skipping."
            return
        fi
        log "Preparing Nuclei-ready targets..."
        
        mkdir -p "$output_dir/nuclei"
        
        # 1. All live URLs (from httpx)
        cat "$output_dir/final_live_subdomains.txt" 2>/dev/null > "$output_dir/nuclei/urls.txt" || true
        cat "$output_dir/final_all_urls.txt" 2>/dev/null >> "$output_dir/nuclei/urls.txt" || true
        sort -u "$output_dir/nuclei/urls.txt" -o "$output_dir/nuclei/urls.txt"
        
        # 2. HTTP/HTTPS targets from Shodan ports
        log "Converting Shodan ports to HTTP targets..."
        > "$output_dir/nuclei/shodan_http_targets.txt"
        
        if [[ -f "$output_dir/shodan/open_ports.txt" ]]; then
            while read -r hostport; do
                [[ -z "$hostport" ]] && continue
                ip=$(echo "$hostport" | cut -d: -f1)
                port=$(echo "$hostport" | cut -d: -f2)
                
                # Common HTTP ports
                case "$port" in
                    80|8080|8000|8008|8081|8888|3000|5000|9000)
                        echo "http://$hostport" >> "$output_dir/nuclei/shodan_http_targets.txt"
                        ;;
                    443|8443|4443|9443)
                        echo "https://$hostport" >> "$output_dir/nuclei/shodan_http_targets.txt"
                        ;;
                    *)
                        # Try both for unknown ports
                        echo "http://$hostport" >> "$output_dir/nuclei/shodan_http_targets.txt"
                        echo "https://$hostport" >> "$output_dir/nuclei/shodan_http_targets.txt"
                        ;;
                esac
            done < "$output_dir/shodan/open_ports.txt"
        fi
        
        sort -u "$output_dir/nuclei/shodan_http_targets.txt" -o "$output_dir/nuclei/shodan_http_targets.txt"
        
        # 3. Probe Shodan targets with httpx for live validation
        log "Probing Shodan HTTP targets..."
        cat "$output_dir/nuclei/shodan_http_targets.txt" | \
            httpx -silent -mc 200,201,301,302,307,308,401,403,405,500 -timeout 10 \
            -o "$output_dir/nuclei/shodan_live.txt" 2>/dev/null || true
        
        # 4. Raw IP:Port targets for non-HTTP nuclei templates (network templates)
        cp "$output_dir/shodan/open_ports.txt" "$output_dir/nuclei/network_targets.txt" 2>/dev/null || true
        
        # 5. Combined master target list for nuclei
        log "Creating master nuclei target list..."
        cat "$output_dir/nuclei/urls.txt" \
            "$output_dir/nuclei/shodan_live.txt" 2>/dev/null | \
            sort -u > "$output_dir/nuclei/all_targets.txt" || true
        
        # 6. CVE-specific targets (IPs with known vulns)
        if [[ -f "$output_dir/shodan/cves.txt" && -s "$output_dir/shodan/cves.txt" ]]; then
            log "Creating CVE-specific target list..."
            cut -d',' -f1 "$output_dir/shodan/cves.txt" | sort -u > "$output_dir/nuclei/cve_ips.txt"
            
            # Create CVE mapping file for reference
            cp "$output_dir/shodan/cves.txt" "$output_dir/nuclei/cve_mapping.csv"
        fi
        
        # 7. Generate nuclei commands - FAST MODE
        cat > "$output_dir/nuclei/run_nuclei.sh" << 'NUCLEI_SCRIPT'
#!/bin/bash
# Auto-generated Nuclei scan - FAST MODE (optimized for speed)

OUTPUT_DIR="$(dirname "$0")"
RESULTS_DIR="$OUTPUT_DIR/results"
mkdir -p "$RESULTS_DIR"

# ══════════════════════════════════════════════════════════════
# SPEED SETTINGS - Adjust based on your network/target tolerance
# ══════════════════════════════════════════════════════════════
CONCURRENCY=50          # Parallel templates
BULK_SIZE=50            # Hosts per template batch
RATE_LIMIT=150          # Requests per second
TIMEOUT=5               # Seconds per request
RETRIES=1               # Retry failed requests
MAX_HOST_ERRORS=30      # Skip host after X errors

# Common fast flags
FAST_FLAGS="-c $CONCURRENCY -bs $BULK_SIZE -rl $RATE_LIMIT -timeout $TIMEOUT -retries $RETRIES -mhe $MAX_HOST_ERRORS -silent -nc -stats"

echo "══════════════════════════════════════════════════════════════"
echo "  NUCLEI FAST SCAN - $(date)"
echo "══════════════════════════════════════════════════════════════"
echo "[*] Targets: $(wc -l < "$OUTPUT_DIR/all_targets.txt" 2>/dev/null || echo 0)"
echo ""

# ─────────────────────────────────────────────────────────────────
# 1. CRITICAL VULNS ONLY (fastest, highest impact)
# ─────────────────────────────────────────────────────────────────
echo "[1/6] Critical vulnerabilities..."
nuclei -l "$OUTPUT_DIR/all_targets.txt" \
    -severity critical \
    -t cves/ -t vulnerabilities/ \
    -et "*/dos/*" -et "*/fuzz/*" -et "*time-based*" -et "*blind*" \
    $FAST_FLAGS \
    -o "$RESULTS_DIR/01_critical.txt" 2>/dev/null &
PID1=$!

# ─────────────────────────────────────────────────────────────────
# 2. SUBDOMAIN TAKEOVER (fast, high impact)
# ─────────────────────────────────────────────────────────────────
echo "[2/6] Subdomain takeover checks..."
nuclei -l "$OUTPUT_DIR/all_targets.txt" \
    -t takeovers/ \
    $FAST_FLAGS \
    -o "$RESULTS_DIR/02_takeovers.txt" 2>/dev/null &
PID2=$!

# ─────────────────────────────────────────────────────────────────
# 3. EXPOSED PANELS & DEFAULT CREDS (quick wins)
# ─────────────────────────────────────────────────────────────────
echo "[3/6] Exposed panels & default logins..."
nuclei -l "$OUTPUT_DIR/all_targets.txt" \
    -t exposed-panels/ -t default-logins/ \
    -severity critical,high \
    $FAST_FLAGS \
    -o "$RESULTS_DIR/03_panels.txt" 2>/dev/null &
PID3=$!

# Wait for parallel scans
wait $PID1 $PID2 $PID3

# ─────────────────────────────────────────────────────────────────
# 4. HIGH SEVERITY MISCONFIGS (fast checks only)
# ─────────────────────────────────────────────────────────────────
echo "[4/6] High severity misconfigurations..."
nuclei -l "$OUTPUT_DIR/all_targets.txt" \
    -t misconfigurations/ -t exposures/ \
    -severity critical,high \
    -et "*fuzz*" -et "*brute*" -et "*sqli*" -et "*xss*" \
    $FAST_FLAGS \
    -o "$RESULTS_DIR/04_misconfig.txt" 2>/dev/null &
PID4=$!

# ─────────────────────────────────────────────────────────────────
# 5. CVE TARGETED (only if Shodan found vulns)
# ─────────────────────────────────────────────────────────────────
if [[ -f "$OUTPUT_DIR/cve_mapping.csv" && -s "$OUTPUT_DIR/cve_mapping.csv" ]]; then
    echo "[5/6] Targeted CVE verification..."
    
    # Extract unique CVE IDs and create targeted scan
    cve_ids=$(cut -d',' -f2 "$OUTPUT_DIR/cve_mapping.csv" | sort -u | head -20)
    cve_targets=$(cut -d',' -f1 "$OUTPUT_DIR/cve_mapping.csv" | sort -u)
    
    # Create temp target file with http/https
    > "$OUTPUT_DIR/cve_http_targets.txt"
    for ip in $cve_targets; do
        echo "http://$ip" >> "$OUTPUT_DIR/cve_http_targets.txt"
        echo "https://$ip" >> "$OUTPUT_DIR/cve_http_targets.txt"
    done
    
    # Scan with specific CVE templates
    nuclei -l "$OUTPUT_DIR/cve_http_targets.txt" \
        -t cves/ \
        -severity critical,high \
        $FAST_FLAGS \
        -o "$RESULTS_DIR/05_cve_targeted.txt" 2>/dev/null &
    PID5=$!
else
    echo "[5/6] Skipped (no CVE targets)"
    PID5=""
fi

# ─────────────────────────────────────────────────────────────────
# 6. QUICK TECH FINGERPRINT (lightweight)
# ─────────────────────────────────────────────────────────────────
echo "[6/6] Quick technology detection..."
nuclei -l "$OUTPUT_DIR/all_targets.txt" \
    -t technologies/ \
    -c 100 -bs 100 -rl 300 -timeout 3 -retries 0 -mhe 50 -silent -nc \
    -o "$RESULTS_DIR/06_tech.txt" 2>/dev/null &
PID6=$!

# Wait for remaining scans
[[ -n "$PID5" ]] && wait $PID5
wait $PID4 $PID6

# ─────────────────────────────────────────────────────────────────
# COMBINE RESULTS
# ─────────────────────────────────────────────────────────────────
echo ""
echo "══════════════════════════════════════════════════════════════"
echo "  SCAN COMPLETE - $(date)"
