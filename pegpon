    echo -e "\n  Tools ready: $available/${#recon_tools[@]}"
    if [[ $unavailable -gt 0 ]]; then
        echo -e "  ${YELLOW}Note: Install missing tools before running full recon${RESET}"
    fi
    
    # ─────────────────────────────────────────────────────────────────
    # SUMMARY
    # ─────────────────────────────────────────────────────────────────
    echo "" >> "$debug_log"
    echo "=== Test completed: $(date) ===" >> "$debug_log"
    echo "Passed: $passed, Failed: $failed" >> "$debug_log"
    
    echo -e "\n${GREEN}═══════════════════════════════════════════════════════════════${RESET}"
    echo -e "  TEST SUMMARY"
    echo -e "${GREEN}═══════════════════════════════════════════════════════════════${RESET}"
    echo -e "  ${GREEN}Passed:${RESET} $passed"
    echo -e "  ${RED}Failed:${RESET} $failed"
    echo -e "  Total:  $((passed + failed))"
    echo ""
    
    if [[ $failed -eq 0 ]]; then
        echo -e "  ${GREEN}✓ ALL TESTS PASSED - Flow logic is working correctly${RESET}"
        echo -e "\n  Test output: $test_dir/"
        echo -e "  Debug log:   $debug_log"
        exit 0
    else
        echo -e "  ${RED}✗ SOME TESTS FAILED - Review errors above${RESET}"
        echo -e "\n  ${YELLOW}Debug log: $debug_log${RESET}"
        echo -e "  Run: cat $debug_log"
        exit 1
    fi
}

# Argument parsing
while getopts ":d:l:t" opt; do
    case $opt in
    d)
        domain="$OPTARG"
        run_recon_for_domain "$domain"
        ;;
    l)
        list="$OPTARG"
        if [[ ! -f "$list" ]]; then
            echo "Error: File '$list' not found."
            exit 1
        fi
        mapfile -t domains <"$list"
        for domain in "${domains[@]}"; do
            [[ -z "$domain" ]] && continue
            run_recon_for_domain "$domain"
        done
        ;;
    t)
        run_flow_test
        ;;
    \?)
        echo "Invalid option: -$OPTARG"
        exit 1
        ;;
    :)
        echo "Option -$OPTARG requires an argument."
        exit 1
        ;;
    esac
done

# Check if no options provided
if [[ -z "${domain:-}" && -z "${list:-}" && "${1:-}" != "-t" ]]; then
    usage
fi
