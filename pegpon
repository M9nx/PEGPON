    echo -e "${GREEN}═══════════════════════════════════════════════════════════════${RESET}\n"
    
    # Check for test dependencies first
    echo -e "${YELLOW}[0/10] Checking test dependencies...${RESET}"
    test_tools=(grep wc cut mkdir cat rm sort)
    missing_tools=()
    
    for tool in "${test_tools[@]}"; do
        if command -v "$tool" &>/dev/null; then
            echo -e "  ${GREEN}✓${RESET} $tool"
        else
            echo -e "  ${RED}✗${RESET} $tool - NOT FOUND"
            missing_tools+=("$tool")
        fi
    done
    
    # Check jq separately (optional for tests but needed for main tool)
    if command -v jq &>/dev/null; then
        echo -e "  ${GREEN}✓${RESET} jq"
    else
        echo -e "  ${YELLOW}!${RESET} jq - not found (needed for main tool, not tests)"
    fi
    
    # Check if grep supports -P (Perl regex)
    if echo "test" | grep -oP 'test' &>/dev/null; then
        echo -e "  ${GREEN}✓${RESET} grep -P (Perl regex support)"
        GREP_PERL=true
    else
        echo -e "  ${YELLOW}!${RESET} grep -P not supported - using basic regex"
        GREP_PERL=false
    fi
    
    if [[ ${#missing_tools[@]} -gt 0 ]]; then
