#!/bin/bash

# Exit on error, undefined vars, and pipe failures
set -euo pipefail

# Colors for output
RED="\e[31m"
GREEN="\e[32m"
YELLOW="\e[33m"
RESET="\e[0m"

# Skip dependency check for test mode (-t)
if [[ "${1:-}" != "-t" ]]; then
    # Check dependencies early
    REQUIRED_TOOLS=(subfinder assetfinder httpx ffuf jq curl katana waybackurls gau findomain chaos github-subdomains dnsx nuclei jsluice)
    for tool in "${REQUIRED_TOOLS[@]}"; do
        if ! command -v "$tool" &>/dev/null; then
            echo -e "${RED}Error:${RESET} '$tool' not found. Please install it."
            exit 1
        fi
    done
fi

